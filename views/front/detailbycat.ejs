<%-include('../partition/Header.ejs')  %>

<section class="blog-list mtb-40">
    <div class="container">
       
        <h1> Blogs</h1>   
      
      <div class="row">
        <% cat.forEach((item)=>{ %>
          <div class="col-md-4">
              <div class="blog-box">
                  <!-- <img src="assets/images/img1.jpg" alt="blog1" /> -->
                  <img src="/upload/<%= item.image %>" alt="">
                  <h3><%= item.title%></h3>
                  <p> <span><%= item.createdAt.toLocaleDateString() %></span></p>
                  <p> <%= item.description.slice(0,90)  %> </p>
                  <a href="/detail/<%= item._id %>" class="btn btn-danger">Read more...</a>
              </div>
          </div>
          <%}) %>
      </div>
    </div>
  </section>



<%-include('../partition/Footer.ejs')  %>