<%-include('../../partition/Header.ejs') %>

<section class="dashboard-wrap mtb-40">
    <div class="container">
        <div class="body-content">
            <div class="row">
                <div class="col-md-3">
                    <div class="dash-left">
                        <ul>
                            <li class="active"><a href="/admin/dashboard">Dashboard</a></li>
                            <li><a href="/admin/Blog" class="active">Blogs</a></li>
                            <li><a href="/admin/category">Categories</a></li>
                            <li><a href="/admin/about">About</a></li>
                            <li><a href="/admin/contact">Contact</a></li>


                            
                            <li><a href="/logout">Logout</a></li>
                        </ul>
                    </div>   
                </div>
                <div class="col-md-9">
                    <div class="dash-right">
                        <div class="dash-header">
                            <div class="dash-title">
                                <h1>Blogs</h1>
                            </div>
                            <div class="dash-nav">
                                <a href="/admin/createBlog" class="btn btn-success">Add Post</a>
                            </div>
                        </div>
                        <table class="table table-bordered table-striped">
                            <tr>
                                <th>#ID</th>
                                <th>Image</th>
                                <th>Category</th>
                                <th>Title</th>
                                <th>Description</th>
                                
                                <th>Action</th>
                            </tr>
                            <% var i=1 %>
                            <% blog.forEach((data)=>{%>
                            <tr>
                               


                                <td><%= i++ %></td>
                                <td><img src="/upload/<%=data.image  %>" alt=""></td>
                                <td><%=data.category_name  %></td>
                                <td><%=data.title%></td>
                                <td><%=data.description %></td>
                                <td>
                                    <a href="/admin/edit/<%=data._id%>" class="btn btn-info btn-sm">Edit</a>
                                    <a href="/admin/delete/<%=data._id%>" class="btn btn-danger btn-sm">Delete</a>
                                </td>
                            </tr>
                            <%}) %>
                        </table>
                    </div>   
                </div>
            </div>
        </div>
    </div>
</section>

<%-include('../../partition/Footer.ejs') %>
